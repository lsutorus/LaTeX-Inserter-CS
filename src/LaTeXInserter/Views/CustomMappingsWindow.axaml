<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LaTeXInserter.ViewModels"
        xmlns:models="using:LaTeXInserter.Models"
        x:Class="LaTeXInserter.Views.CustomMappingsWindow"
        x:DataType="vm:CustomMappingsViewModel"
        Title="Custom Mappings"
        Width="520"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Shared row template used by both tabs. Display (TextBlocks) and inline edit
             (TextBoxes) swap on the IsEditing flag; display never steals row selection. -->
        <DataTemplate x:DataType="models:MappingItem" x:Key="MappingRowTemplate">
            <Grid ColumnDefinitions="16,*" Margin="0,1">
                <TextBlock Grid.Column="0"
                           Text="*"
                           FontWeight="Bold"
                           Foreground="#F97316"
                           IsVisible="{Binding IsOverride}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <Grid Grid.Column="1" ColumnDefinitions="*,*">
                    <!-- Display -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Command}"
                               IsVisible="{Binding !IsEditing}"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Character}"
                               IsVisible="{Binding !IsEditing}"
                               Margin="4,0,8,0"
                               VerticalAlignment="Center" />
                    <!-- Edit -->
                    <TextBox Grid.Column="0"
                             Text="{Binding Command}"
                             IsVisible="{Binding IsEditing}"
                             Classes.mapping-error="{Binding HasValidationError}"
                             Margin="0,0,4,0"
                             KeyDown="OnEditKeyDown" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Character}"
                             IsVisible="{Binding IsEditing}"
                             Margin="4,0,8,0"
                             KeyDown="OnEditKeyDown" />
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <!-- Validation error: red border -->
        <Style Selector="TextBox.mapping-error">
            <Setter Property="BorderBrush" Value="#EF4444" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Delete button: red -->
        <Style Selector="Button.mapping-delete">
            <Setter Property="Foreground" Value="#EF4444" />
        </Style>
        <!-- Revert button: red -->
        <Style Selector="Button.mapping-revert">
            <Setter Property="Foreground" Value="#EF4444" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Neutral selection background (NOT the app accent) for both ListBoxes -->
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Bottom button bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#444444" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Left action group -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                    <Button Content="Edit"
                            Command="{Binding EditCommand}" />
                    <Button Content="Delete"
                            Command="{Binding DeleteCommand}"
                            Classes="mapping-delete" />
                    <Button Content="Revert to Default"
                            Command="{Binding RevertToDefaultCommand}"
                            Classes="mapping-revert"
                            IsVisible="{Binding !IsCustomTab}" />
                </StackPanel>
                <!-- Right commit group -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search (filters the active tab's list, live) + info -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,8,12,4">
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search command…" />
            <Border Grid.Column="1"
                    Width="18" Height="18" CornerRadius="9"
                    Background="Transparent" BorderBrush="#888888" BorderThickness="1"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center" Cursor="Help">
                <ToolTip.Tip>
                    <TextBlock TextWrapping="Wrap" MaxWidth="280">
                        <Run Text="*" Foreground="#F97316" FontWeight="Bold" />
                        <Run Text=" overrides a default mapping with a different value." />
                        <LineBreak />
                        <Run Text="Custom Mappings: your `\command` → char pairs. A custom mapping with the same command as a default overrides it." />
                        <LineBreak />
                        <Run Text="Default Mappings: built-in set (read-only); edit one to create an override." />
                    </TextBlock>
                </ToolTip.Tip>
                <TextBlock Text="i"
                           FontSize="12" FontWeight="Bold"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </Grid>

        <!-- Tab control -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="12,0,12,8">
            <!-- Tab 1: Custom Mappings -->
            <TabItem Header="Custom Mappings">
                <DockPanel>
                    <!-- Add form -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="#444444" BorderThickness="0,0,0,1"
                            Padding="0,0,0,6" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewCommand}"
                                     PlaceholderText="\command"
                                     Classes.mapping-error="{Binding HasNewCommandValidationError}"
                                     Margin="0,0,4,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewCharacter}"
                                     PlaceholderText="Unicode char"
                                     Margin="4,0,4,0" />
                            <Button Grid.Column="2"
                                    Content="Add"
                                    Command="{Binding AddCommand}" />
                        </Grid>
                    </Border>

                    <ListBox x:Name="CustomMappingsList"
                             ItemsSource="{Binding CustomMappings}"
                             SelectedItem="{Binding SelectedCustomItem}"
                             DoubleTapped="OnCustomItemDoubleTapped"
                             ItemTemplate="{StaticResource MappingRowTemplate}" />
                </DockPanel>
            </TabItem>

            <!-- Tab 2: Default Mappings -->
            <TabItem Header="Default Mappings">
                <ListBox x:Name="DefaultMappingsList"
                         ItemsSource="{Binding DefaultMappings}"
                         SelectedItem="{Binding SelectedDefaultItem}"
                         DoubleTapped="OnDefaultItemDoubleTapped"
                         ItemTemplate="{StaticResource MappingRowTemplate}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
