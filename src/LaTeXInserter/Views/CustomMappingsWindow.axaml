<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LaTeXInserter.ViewModels"
        xmlns:models="using:LaTeXInserter.Models"
        x:Class="LaTeXInserter.Views.CustomMappingsWindow"
        x:DataType="vm:CustomMappingsViewModel"
        Title="Custom Mappings"
        Width="450"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Validation error: red border -->
        <Style Selector="TextBox.mapping-error">
            <Setter Property="BorderBrush" Value="#EF4444" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Delete button: red accent -->
        <Style Selector="Button.mapping-delete">
            <Setter Property="Foreground" Value="#EF4444" />
        </Style>
        <!-- Revert button: red accent -->
        <Style Selector="Button.mapping-revert">
            <Setter Property="Foreground" Value="#EF4444" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Bottom button bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#444444" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Left action group -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                    <Button Content="Add"
                            Command="{Binding AddCommand}" />
                    <Button Content="Edit"
                            Command="{Binding EditCommand}" />
                    <Button Content="Delete"
                            Command="{Binding DeleteCommand}"
                            Classes="mapping-delete" />
                    <Button Content="Revert to Default"
                            Command="{Binding RevertToDefaultCommand}"
                            Classes="mapping-revert" />
                </StackPanel>
                <!-- Right commit group -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Save"
                            Command="{Binding SaveCommand}" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab control -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Tab 1: Custom Mappings -->
            <TabItem Header="Custom Mappings">
                <ListBox x:Name="CustomMappingsList"
                         ItemsSource="{Binding CustomMappings}"
                         SelectedItem="{Binding SelectedCustomItem}"
                         DoubleTapped="OnCustomItemDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:MappingItem">
                            <Grid ColumnDefinitions="Auto,*,*" Margin="0,2">
                                <!-- Asterisk for overrides -->
                                <TextBlock Grid.Column="0"
                                           Text="*"
                                           FontWeight="Bold"
                                           Foreground="#F97316"
                                           Width="16"
                                           IsVisible="{Binding IsOverride}"
                                           VerticalAlignment="Center" />
                                <!-- Command field -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding Command}"
                                         IsReadOnly="{Binding !IsEditing}"
                                         Classes.mapping-error="{Binding HasValidationError}"
                                         Margin="0,0,4,0"
                                         KeyDown="OnEditKeyDown"
                                         LostFocus="OnEditLostFocus" />
                                <!-- Character field -->
                                <TextBox Grid.Column="2"
                                         Text="{Binding Character}"
                                         IsReadOnly="{Binding !IsEditing}"
                                         Margin="4,0,0,0"
                                         KeyDown="OnEditKeyDown"
                                         LostFocus="OnEditLostFocus" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>

            <!-- Tab 2: Default Mappings -->
            <TabItem Header="Default Mappings">
                <ListBox x:Name="DefaultMappingsList"
                         ItemsSource="{Binding DefaultMappings}"
                         SelectedItem="{Binding SelectedDefaultItem}"
                         DoubleTapped="OnDefaultItemDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:MappingItem">
                            <Grid ColumnDefinitions="Auto,*,*" Margin="0,2">
                                <!-- Asterisk for overrides -->
                                <TextBlock Grid.Column="0"
                                           Text="*"
                                           FontWeight="Bold"
                                           Foreground="#F97316"
                                           Width="16"
                                           IsVisible="{Binding IsOverride}"
                                           VerticalAlignment="Center" />
                                <!-- Command field -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding Command}"
                                         IsReadOnly="{Binding !IsEditing}"
                                         Margin="0,0,4,0"
                                         KeyDown="OnEditKeyDown"
                                         LostFocus="OnEditLostFocus" />
                                <!-- Character field -->
                                <TextBox Grid.Column="2"
                                         Text="{Binding Character}"
                                         IsReadOnly="{Binding !IsEditing}"
                                         Margin="4,0,0,0"
                                         KeyDown="OnEditKeyDown"
                                         LostFocus="OnEditLostFocus" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
